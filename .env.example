# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database connection ───────────────────────────────────────────────────
# Point at your existing SQL Server instance, or "mssql" if using the
# local Docker mirror defined in docker-compose.yml.
DB_SERVER=your-sql-server-host-or-ip
DB_NAME=embroidery
DB_USER=sa
DB_PASSWORD=YourStrongPassword123!

# Set to "no" only if your server has a valid, trusted TLS certificate.
DB_TRUST_CERT=yes

# Optional: override the ODBC driver name if you installed a different version
# DB_DRIVER=ODBC Driver 18 for SQL Server

# ── MCP server ────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000
